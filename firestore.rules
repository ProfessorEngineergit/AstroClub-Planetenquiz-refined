rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /scores/{doc} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly([
                      'name',
                      'score',
                      'maxScore',
                      'percent',
                      'lang',
                      'quizId',
                      'durationSeconds',
                      'createdAt'
                    ])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 1
                    && request.resource.data.name.size() <= 30
                    && request.resource.data.score is number
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= 160
                    && request.resource.data.maxScore == 160
                    && request.resource.data.percent is number
                    && request.resource.data.percent >= 0
                    && request.resource.data.percent <= 100
                    && (request.resource.data.lang == 'de' || request.resource.data.lang == 'en')
                    && request.resource.data.quizId == 'astroclub-planetenquiz'
                    && request.resource.data.durationSeconds is number
                    && request.resource.data.durationSeconds >= 0
                    && request.resource.data.durationSeconds <= 86400
                    && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }
  }
}
